\nvar meshes = def.getMeshesAtDepth(depth); \n\n// Get bounding box of the shape\nvar bbox = def.getBoundingBox();\nvar [minX, maxX] = [bbox.x, bbox.x+bbox.width];\nvar [minY, maxY] = [bbox.y, bbox.y+bbox.height];\n\n\nfor (var mesh of meshes) {\n    var path = mesh.getPathAtIndex(0); \n    path.resample(1); \n    var pd = path.pathData(); \n\n    for (var idx = 0; idx < pd.length; idx++) {\n        if (pd[idx].type == \"close\") { \n            continue;\n        }\n        \n        // set 'xpos' and \"ypos\" in the range 0 to 1 using bounding box\n        let xpos = cavalry.norm(pd[idx].point.x, minX, maxX);\n        let ypos = cavalry.norm(pd[idx].point.y, minY, maxY);\n        \n        let powerX = 0;\n        let powerY = 0;\n       \n        \n        \n        // X Position\n        // bias direction (xDir, yDir) and mouse position(Null obejct) is inversely related\n        let xDir = cavalry.map(cavalry.clamp(n1.x, -width/2, width/2), -width/2, width/2, width/2, -width/2);\n        if ( xDir > 0 ){\n            // power in the range of 1-3(max exponent)\n            powerX = cavalry.map(xDir, 0, width/2, 1, maxExp);\n            \n            xpos = xpos ** powerX;\n        }else{\n            //Reverse the mapping\n            xpos = cavalry.norm(pd[idx].point.x, maxX, minX);\n            powerX = cavalry.map(xDir, -width/2, 0, maxExp, 1);\n  \n            xpos = cavalry.map(xpos ** powerX, 0, 1, 1, 0);     \n\n        }\n        \n        // Y Position\n        let yDir = cavalry.map(cavalry.clamp(n1.y, -height/2, height/2), -height/2, height/2, maxY, minY);\n        if ( yDir > 0 ){\n            //power in the range of 1-3\n            powerY = cavalry.map(yDir, 0, height/2, 1, maxExp);\n            ypos = ypos ** powerY;\n        }else{\n            //ypos needs to be reversed \n            ypos = cavalry.norm(pd[idx].point.y, maxY, minY);\n            powerY = cavalry.map(yDir, -height/2, 0, maxExp, 1);\n  \n            ypos = cavalry.map(ypos ** powerY, 0, 1, 1, 0);     \n\n        }\n\n        pd[idx].point.x = cavalry.map(xpos, 0, 1, minX ,maxX);\n        pd[idx].point.y = cavalry.map(ypos, 0, 1, minY ,maxY);\n \n    }\n    // Set the point data\n    path.setPathData(pd);\n    // Set the path\n    mesh.setPathAtIndex(0, path);\n}\n// Set the mesh\ndef.setMeshesAtDepth(depth, meshes);","varType":"string"},"generator":{"value":{"meshes":[{"address":[0,0],"fillType":0,"path":null},{"address":[0],"fillType":0,"path":null}],"version":1},"varType":"polyMesh"},"niceName":{"value":"JavaScript Deformer [Duplicator] 1","varType":"string"},"uuid":{"value":"349db446-333a-4b11-a802-67fce3cc0b2c","varType":"string"}},"nodeId":"javaScriptDeformer#17","nodeType":"javaScriptDeformer"},{"attributes":{"array":{"list":[{"instanceName":"n1","value":{"x":0,"y":90.88601684570312},"varType":"double2"},{"instanceName":"width","value":1080,"varType":"double"},{"instanceName":"height","value":1080,"varType":"double"},{"instanceName":"maxExp","value":3,"varType":"double"}]},"colorId":{"value":0,"varType":"int"},"expression":{"value":"var depth = def.highestDepthWithPath(); \nvar pi = 3.14159;\nvar frequency = 4;\nvar amplitude = 30;\n \nvar meshes = def.getMeshesAtDepth(depth); \n\n// Get bounding box of the shape\nvar bbox = def.getBoundingBox();\nvar [minX, maxX] = [bbox.x, bbox.x+bbox.width];\nvar [minY, maxY] = [bbox.y, bbox.y+bbox.height];\n\n\nfor (var mesh of meshes) {\n    var path = mesh.getPathAtIndex(0); \n    path.resample(1); \n    var pd = path.pathData(); \n\n    for (var idx = 0; idx < pd.length; idx++) {\n        if (pd[idx].type == \"close\") { \n            continue;\n        }\n        \n        // set 'xpos' and \"ypos\" in the range 0 to 1 using bounding box\n        let xpos = cavalry.norm(pd[idx].point.x, minX, maxX);\n        let ypos = cavalry.norm(pd[idx].point.y, minY, maxY);\n        \n        let powerX = 0;\n        let powerY = 0;\n       \n        \n        \n        // X Position\n        // bias direction (xDir, yDir) and mouse position(Null obejct) is inversely related\n        let xDir = cavalry.map(cavalry.clamp(n1.x, -width/2, width/2), -width/2, width/2, maxX, minX);\n        if ( xDir > 0 ){\n            // power in the range of 1-3(max exponent)\n            powerX = cavalry.map(xDir, 0, width/2, 1, maxExp);\n            \n            xpos = xpos ** powerX;\n        }else{\n            //Reverse the mapping\n            xpos = cavalry.norm(pd[idx].point.x, maxX, minX);\n            powerX = cavalry.map(xDir, -width/2, 0, maxExp, 1);\n  \n            xpos = cavalry.map(xpos ** powerX, 0, 1, 1, 0);     \n\n        }\n        \n        // Y Position\n        let yDir = cavalry.map(cavalry.clamp(n1.y, -height/2, height/2), -height/2, height/2, maxY, minY);\n        if ( yDir > 0 ){\n            //power in the range of 1-3\n            powerY = cavalry.map(yDir, 0, height/2, 1, maxExp);\n            ypos = ypos ** powerY;\n        }else{\n            //ypos needs to be reversed \n            ypos = cavalry.norm(pd[idx].point.y, maxY, minY);\n            powerY = cavalry.map(yDir, -height/2, 0, maxExp, 1);\n  \n            ypos = cavalry.map(ypos ** powerY, 0, 1, 1, 0);     \n\n        }\n\n        pd[idx].point.x = cavalry.map(xpos, 0, 1, minX ,maxX);\n        pd[idx].point.y = cavalry.map(ypos, 0, 1, minY ,maxY);\n \n    }\n    // Set the point data\n    path.setPathData(pd);\n    // Set the path\n    mesh.setPathAtIndex(0, path);\n}\n// Set the mesh\ndef.setMeshesAtDepth(depth, meshes);","varType":"string"},"generator":{"value":{"meshes":[{"address":[0,0],"fillType":0,"path":null},{"address":[0],"fillType":0,"path":null}],"version":1},"varType":"polyMesh"},"niceName":{"value":"JavaScript Deformer [Duplicator]","varType":"string"},"uuid":{"value":"349db446-333a-4b11-a802-67fce3cc0b2c","varType":"string"}},"nodeId":"javaScriptDeformer#16","nodeType":"javaScriptDeformer"}],"other":{"viewport":{"backgroundMode":0,"rulers":{"compNode#23":{"horizontal":[],"vertical